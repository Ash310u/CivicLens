VITE_API_URL=http://localhost:3000
VITE_APP_BASE_URL=/

# Cloudinary (unsigned upload preset for waste photos)
# Create an unsigned upload preset in the Cloudinary console (e.g. name: civiclens).
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# OpenCage Geocoding API key (used to convert report location text into latitude/longitude)
VITE_OPENCAGE_API_KEY=
